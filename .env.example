# Next.js Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Devashish Portfolio

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Optional: Email Service (if you have contact form)
# SENDGRID_API_KEY=your-sendgrid-key
# CONTACT_EMAIL=your-email@example.com

# Optional: GitHub API (if fetching repos dynamically)
# GITHUB_TOKEN=your-github-token

# Build configuration
# NODE_ENV will be set automatically by Netlify
